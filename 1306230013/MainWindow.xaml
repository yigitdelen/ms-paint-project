<Window x:Class="_1306230013.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MS Paint OOP Projesi" Height="700" Width="1000">

    <Window.Resources>
        <Style x:Key="CircleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="14" 
                                BorderBrush="#CCCCCC" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <GroupBox Header="Araçlar" Margin="8,0" Padding="5" Width="255">
                    <UniformGrid Rows="2" Columns="3">
                        <Button x:Name="BtnPen" Content="Kalem" Click="BtnTool_Click" Margin="3" Padding="5"/>
                        <Button x:Name="BtnRect" Content="Dikdörtgen" Click="BtnTool_Click" Margin="3" Padding="5"/>
                        <Button x:Name="BtnCircle" Content="Daire" Click="BtnTool_Click" Margin="3" Padding="5"/>
                        <Button x:Name="BtnText" Content="Metin" Click="BtnTool_Click" Margin="3" Padding="5"/>
                        <Button x:Name="BtnEraser" Content="Silgi" Click="BtnTool_Click" Margin="3" Padding="5"/>
                    </UniformGrid>
                </GroupBox>

                <GroupBox Header="Renkler" Margin="8,0" Padding="5">
                    <UniformGrid Columns="5">
                        <Button Background="Black" Style="{StaticResource CircleButtonStyle}" Click="BtnColor_Click"/>
                        <Button Background="Red" Style="{StaticResource CircleButtonStyle}" Click="BtnColor_Click"/>
                        <Button Background="Blue" Style="{StaticResource CircleButtonStyle}" Click="BtnColor_Click"/>
                        <Button Background="Green" Style="{StaticResource CircleButtonStyle}" Click="BtnColor_Click"/>
                        <Button Background="Yellow" Style="{StaticResource CircleButtonStyle}" Click="BtnColor_Click"/>
                        <Button Background="Orange" Style="{StaticResource CircleButtonStyle}" Click="BtnColor_Click"/>
                        <Button Background="Purple" Style="{StaticResource CircleButtonStyle}" Click="BtnColor_Click"/>
                        <Button Background="Pink" Style="{StaticResource CircleButtonStyle}" Click="BtnColor_Click"/>
                        <Button Background="Brown" Style="{StaticResource CircleButtonStyle}" Click="BtnColor_Click"/>
                        <Button Background="Gray" Style="{StaticResource CircleButtonStyle}" Click="BtnColor_Click"/>
                    </UniformGrid>
                </GroupBox>

                <GroupBox Header="Ayarlar" Margin="8,0" Padding="8">
                    <StackPanel Width="140">
                        <TextBlock Text="Kalınlık" FontSize="11" Margin="0,0,0,2"/>
                        <Slider x:Name="SliderThickness" Minimum="1" Maximum="20" Value="2" Margin="0,0,0,8"/>
                        <TextBlock Text="Yazı Boyutu" FontSize="11" Margin="0,0,0,2"/>
                        <ComboBox x:Name="ComboFontSize" SelectedIndex="1">
                            <ComboBoxItem Content="8"/>
                            <ComboBoxItem Content="12"/>
                            <ComboBoxItem Content="16"/>
                            <ComboBoxItem Content="20"/>
                            <ComboBoxItem Content="24"/>
                            <ComboBoxItem Content="28"/>
                            <ComboBoxItem Content="32"/>
                            <ComboBoxItem Content="36"/>
                            <ComboBoxItem Content="40"/>
                            <ComboBoxItem Content="44"/>
                            <ComboBoxItem Content="48"/>
                        </ComboBox>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="İşlemler" Margin="8,0" Padding="5">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Geri Al" Width="50" Height="30" Margin="3" Click="BtnUndo_Click"/>
                        <Button Content="İleri Al" Width="50" Height="30" Margin="3" Click="BtnRedo_Click"/>
                        <Button Content="Temizle" Width="50" Height="30" Margin="3" Click="BtnClear_Click"/>
                        <Button Content="KAYDET" Width="65" Height="35" Margin="5" Click="BtnSave_Click" 
                                Background="#007BFF" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </Border>

        <Border x:Name="BorderForCanvas" Grid.Row="1" Background="White">
            <Canvas x:Name="PaintCanvas" Background="White"
                    MouseDown="PaintCanvas_MouseDown" 
                    MouseMove="PaintCanvas_MouseMove" 
                    MouseUp="PaintCanvas_MouseUp"
                    ClipToBounds="True"/>
        </Border>
    </Grid>
</Window>